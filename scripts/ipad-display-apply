#!/usr/bin/env bash
set -euo pipefail

export DISPLAY="${DISPLAY:-:0}"
export XAUTHORITY="${XAUTHORITY:-$HOME/.Xauthority}"

if xrandr --query | grep -q '^HDMI-1 connected'; then
  xrandr \
    --output HDMI-1 --mode 1280x800 --rate 59.91 --pos 0x200 \
    --output eDP-1 --primary --mode 1920x1200 --pos 1280x0
else
  xrandr \
    --output HDMI-1 --off \
    --output eDP-1 --primary --mode 1920x1200 --pos 0x0
fi
